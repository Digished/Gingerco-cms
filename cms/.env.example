# =============================================================================
# GINGERCO CMS (Payload CMS) - ENVIRONMENT VARIABLES
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to Git -- it is in .gitignore.
#
# For PRODUCTION (Vercel):
#   Set these in Vercel Dashboard > Settings > Environment Variables
# =============================================================================

# --- REQUIRED ---

# DATABASE_URL: PostgreSQL connection string
#   For Supabase: Go to Project Settings > Database > Connection string (URI)
#   For Vercel Postgres: Automatically set when you connect the integration
#   Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://postgres:your-password@db.your-project.supabase.co:5432/postgres

# PAYLOAD_SECRET: Used to encrypt cookies, API keys, and other sensitive data
#   Must be a long, random string (32+ characters)
#   Generate with: openssl rand -hex 32
PAYLOAD_SECRET=your-payload-secret-here

# --- REQUIRED: Resend Email ---
# Sign up at https://resend.com, then go to API Keys to generate your key.
# You must also verify your sending domain in the Resend dashboard.
RESEND_API_KEY=re_your_api_key_here

# The "from" email address for all outgoing emails.
# Must match a verified domain in your Resend account.
RESEND_FROM_EMAIL=events@gingerandco.at

# --- RECOMMENDED ---

# NEXT_PUBLIC_SERVER_URL: The public-facing website URL (used for links back to the site)
#   Local: http://localhost:3000
#   Production: https://gingerandco.at
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# NEXT_PUBLIC_CMS_URL: The URL where this CMS is deployed (used for API links in emails)
#   Only needed if the CMS is hosted separately from the main website.
#   If not set, falls back to NEXT_PUBLIC_SERVER_URL.
#   Production: https://cms.gingerandco.at or https://your-project.vercel.app
# NEXT_PUBLIC_CMS_URL=https://your-cms-deployment.vercel.app

# --- CRON JOBS ---
# CRON_SECRET: Vercel auto-generates this when it detects crons in vercel.json.
# It will appear in Vercel Dashboard > Settings > Environment Variables automatically
# after the first deployment with crons configured.
# If it remains empty, generate one manually and add it to Vercel:
#   openssl rand -hex 32
# CRON_SECRET=your-cron-secret-here

# --- OPTIONAL: Media Storage ---
# Choose ONE storage backend. If both are configured, Vercel Blob takes priority.

# Option 1: Vercel Blob (auto-set when Vercel Blob integration is connected)
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxx

# Option 2: Supabase Storage (S3-compatible)
#   1. Go to Supabase Dashboard > Storage > Create bucket called "media" (set to public)
#   2. Go to Project Settings > API > S3 Access Keys > Generate new key
#   3. Your endpoint is: https://<project-ref>.supabase.co/storage/v1/s3
#   4. Region matches your Supabase project region (e.g. eu-central-1)
# SUPABASE_S3_ENDPOINT=https://your-project.supabase.co/storage/v1/s3
# SUPABASE_S3_BUCKET=media
# SUPABASE_S3_ACCESS_KEY=your-s3-access-key
# SUPABASE_S3_SECRET_KEY=your-s3-secret-key
# SUPABASE_S3_REGION=eu-central-1
